# Admin reset step 2: executing reset with the correct key clears the
# database, preserves the .np/ directory, creates a backup file, and
# deletes the hash file.

np-init AR
np-seed task 'Task before reset' reset-agent TASK

exec np admin reset --json
np-capture KEY reset_key

exec np admin reset --reset-key $KEY --json
np-json-has action reset
np-capture BACKUP backup_path

# Database is cleared.
exec np list --json
np-json-array-len items 0

# .np/ directory still exists.
exists .np

# Backup file was created.
exists $BACKUP

# Hash file is removed after successful reset.
! exists .np/reset-key-hash.txt
