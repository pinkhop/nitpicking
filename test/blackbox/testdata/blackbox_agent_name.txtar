# Verify that 'np agent name' produces an "agent-" prefixed four-part hyphenated
# name without requiring a database (unseeded mode).

exec np agent name
stdout '^agent-[a-z]+-[a-z]+-[a-z]+$'

# Verify that '--seed=<value>' produces identical output on repeated calls.
# Two invocations with the same seed must emit the same name.

exec np agent name --seed=hello
cp stdout first_name.txt

exec np agent name --seed=hello
cp stdout second_name.txt

cmp first_name.txt second_name.txt

# Verify that the seeded output still matches the "agent-" prefixed four-part shape.

exec np agent name --seed=hello
stdout '^agent-[a-z]+-[a-z]+-[a-z]+$'

# Verify that a different seed produces a different name.
# The two seeds are chosen empirically: 'hello' -> 'agent-sharp-spark-chase',
# 'world' -> 'agent-grand-glacier-trace'.

exec np agent name --seed=hello
stdout '^agent-sharp-spark-chase$'

exec np agent name --seed=world
stdout '^agent-grand-glacier-trace$'

# Verify that whitespace-only seeds are rejected with a non-zero exit code.
# urfave/cli strips trailing whitespace from string flags, so a seed of only
# spaces arrives with IsSet("seed")==true and seed=="" — the same condition as
# an explicit --seed="" — and must be rejected rather than silently falling
# through to the unseeded random path.

! exec np agent name --seed=
stderr '--seed must not be blank'

! exec np agent name '--seed=   '
stderr '--seed must not be blank'
