# Verify that a deferred issue can be re-claimed. The primary state remains
# deferred; claiming is recorded as transient metadata only.

np-init EDGE
np-seed task 'Deferred then reclaimed' edge-agent TASK --claim

exec np issue defer --claim $TASK_CLAIM --json

exec np claim $TASK --author edge-agent --json
np-capture NEW_CLAIM claim_id

exec np show $TASK --json
np-json-has state deferred
np-json-has claim_author edge-agent
