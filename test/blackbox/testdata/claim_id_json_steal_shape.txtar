# Verify that 'np claim --steal --json' produces valid JSON with stolen=true
# and all snake_case keys after stealing a stale claim.

np-init CI
np-seed task 'Task for steal audit' steal-audit TASK

# Create a claim with a very short duration so it goes stale immediately.
exec np claim $TASK --author original-claimer --duration 1ms --json

# Steal the now-stale claim.
exec np claim $TASK --author steal-audit --steal --json
np-json-has stolen true

# No PascalCase key leaks.
! stdout '"IssueID"'
! stdout '"ClaimID"'
! stdout '"Stolen"'
