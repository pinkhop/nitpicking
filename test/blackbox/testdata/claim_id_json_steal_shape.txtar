# Verify that 'np claim <ID> --json' on a stale claim produces valid JSON
# with snake_case keys. Stealing mechanics (--steal flag, stolen field) are
# removed; a stale claim is simply overwritten by a new claim.

np-init CI
np-seed task 'Task for stale claim reclaim audit' steal-audit TASK

# Create a claim with a very short duration so it goes stale immediately.
exec np claim $TASK --author original-claimer --duration 1ms --json

# Claim the issue again after the previous claim goes stale.
exec np claim $TASK --author steal-audit --json
! np-json-no-field claim_id
np-json-no-field stolen

# No PascalCase key leaks.
! stdout '"IssueID"'
! stdout '"ClaimID"'
! stdout '"Stolen"'
