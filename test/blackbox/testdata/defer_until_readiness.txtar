# Deferred issue with --until: show includes the revisit date,
# deferred issues are not ready, and descendants of deferred epics
# are not ready.

np-init DUR
np-seed task 'Deferred task' defer-agent TASK --claim

exec np issue defer --claim $TASK_CLAIM --until 2026-06-15 --json

exec np show $TASK --json
np-json-has state deferred
np-json-has is_ready false
