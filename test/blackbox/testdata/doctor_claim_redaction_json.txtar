# Doctor JSON output must not expose claim IDs regardless of claim state.
# The claim ID is a bearer token; leaking it would allow unauthorized
# mutations. Claims are transient local bookkeeping — doctor no longer
# reports stale claims as findings; it only reports structural issues.

np-init DRRED
np-seed task 'Claimed task for doctor' doctor-redact TASK

# Claim the task.
exec np claim $TASK --author doctor-redact --json
np-capture CLAIM claim_id

# Doctor should run successfully and not expose the claim ID.
exec np admin doctor --json

# The claim ID bearer token must not appear in the output.
! stdout $CLAIM@R
! stdout '"claim_id"'
