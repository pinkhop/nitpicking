# git-ignore check: JSON output with a git repo missing .np/ in .gitignore.
# The warnings array contains the finding. Exits 1.

np-init GITJ

! exec np admin doctor --json
np-json-array-len errors 0
np-json-array-len warnings 1
stdout '"git-ignore"'
stdout '.np/ directory is not ignored'

-- CLAUDE.md --
Use np to manage issues. Run `np agent prime` for setup.
-- .git/config --
[core]
	repositoryformatversion = 0
	filemode = true
-- .gitignore --
node_modules/
