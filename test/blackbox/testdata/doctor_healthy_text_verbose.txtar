# Healthy text output (verbose mode): shows all four category headers and
# the passing glyph for all checks. Summary is "16 checks, 0 findings."
# Exit 0.

np-init HLTV
np-seed task 'Healthy task' hltv-agent TASK

exec np admin doctor --verbose
stdout 'np admin doctor'
stdout 'Database'
stdout 'Environment'
stdout 'Graph health'
stdout 'Issue lifecycle'
stdout '16 checks, 0 findings.'

-- CLAUDE.md --
Use np to manage issues. Run `np agent prime` for setup.
-- .git/config --
[core]
	repositoryformatversion = 0
	filemode = true
-- .gitignore --
.np/
