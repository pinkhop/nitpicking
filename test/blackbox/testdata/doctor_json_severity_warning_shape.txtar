# Verify that 'np admin doctor --severity warning --json' produces valid JSON
# with the expected shape when filtering by warning severity.

np-init DR
np-seed task 'Healthy task' doctor-audit TASK

exec np admin doctor --severity warning --json

# Top-level shape: errors and warnings always present.
! np-json-no-field errors
! np-json-no-field warnings

# Old shape fields must not leak.
np-json-no-field healthy
np-json-no-field findings

# No is_deleted field leaks.
np-json-no-field is_deleted

# No PascalCase key leaks.
! stdout '"Category"'
! stdout '"Severity"'
! stdout '"Message"'

-- CLAUDE.md --
Use np to manage issues. Run `np agent prime` for setup.
