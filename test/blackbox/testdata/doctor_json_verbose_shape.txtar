# Verify that 'np admin doctor --verbose --json' produces the expected JSON
# shape: errors and warnings arrays always present, passed and skipped arrays
# in verbose mode (may be empty when Doctor is a stub).

np-init DR
np-seed task 'Healthy task' doctor-audit TASK

exec np admin doctor --verbose --json

# Top-level shape: errors and warnings always present.
! np-json-no-field errors
! np-json-no-field warnings

# Old shape fields must not leak.
np-json-no-field healthy
np-json-no-field findings
np-json-no-field checks

# No PascalCase key leaks.
! stdout '"Category"'
! stdout '"Severity"'
! stdout '"Message"'
! stdout '"Name"'
! stdout '"Status"'
! stdout '"Errors"'
! stdout '"Warnings"'

-- CLAUDE.md --
Use np to manage issues. Run `np agent prime` for setup.
