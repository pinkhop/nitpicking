# Verify that the JSON output of issue history does not leak the claim ID
# (bearer token). Claiming no longer produces a history event; only "created"
# appears for a freshly seeded issue.

np-init HJ
np-seed task 'History JSON claim redact' hist-agent TASK --claim

exec np issue history $TASK --json
stdout '"event_type": "created"'
! stdout '"event_type": "claimed"'
! stdout $TASK_CLAIM
