# Verify that re-importing a JSONL file with the same idempotency keys
# does not create duplicate issues.

np-init IR

exec np import jsonl testdata/rerun.jsonl --author import-agent --json
stdout '"created": 1'

# Import the same file again.
exec np import jsonl testdata/rerun.jsonl --author import-agent --json
stdout '"created": 1'

# There should still be only one issue matching the title.
exec np list --json
np-json-array-len items 1

-- testdata/rerun.jsonl --
{"idempotency_key":"idempotent-1","role":"task","title":"Idempotent task"}
