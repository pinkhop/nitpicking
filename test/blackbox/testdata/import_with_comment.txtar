# Verify that np import attaches comments to imported issues.

np-init IW

exec np import jsonl testdata/with_comment.jsonl --author import-agent --json
stdout '"created": 1'

# The imported issue should exist.
exec np issue search "Commented import" --json
! np-json-array-len items 0

-- testdata/with_comment.jsonl --
{"idempotency_key":"comment-1","role":"task","title":"Commented import","comment":"Migrated from external tracker."}
