# Verify that np list accepts multiple --state flags and returns issues
# matching any of the specified states.

np-init MS
np-seed task 'Open task' multi-agent OPEN_TASK
np-seed task 'Closed task' multi-agent CLOSE_TASK

exec np claim $CLOSE_TASK --author multi-agent --json
np-capture CLOSE_CLAIM claim_id

exec np close --claim $CLOSE_CLAIM --reason 'done' --json

exec np list --state open --state closed --json
np-json-array-len issues 2
