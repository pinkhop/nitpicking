# Verify that a single --state flag returns only issues in that primary state.
# Claimed issues have primary state "open" and secondary_state "claimed".

np-init SS
np-seed task 'Open task' single-agent OPEN_TASK
np-seed task 'Claimed task' single-agent CLAIM_TASK

exec np claim $CLAIM_TASK --author single-agent --json

# Both tasks are open (claimed is a secondary state, not primary).
exec np list --state open --json
np-json-array-len items 2

# Filter by closed returns nothing.
exec np list --state closed --json
np-json-array-len items 0
