# Verify that 'np rel blocks list --json' produces valid JSON with snake_case
# keys, issue_id, and a relationships array with source_id, target_id, type.

np-init RB
np-seed task 'Blocker task' rel-agent BLOCKER
np-seed task 'Blocked task' rel-agent BLOCKED
np-seed-rel BLOCKED blocked_by BLOCKER rel-agent

exec np rel blocks list $BLOCKED --json
np-json-has issue_id $BLOCKED
! np-json-array-len relationships 0

# Relationship fields are snake_case.
stdout '"source_id"'
stdout '"target_id"'
stdout '"type"'

# No PascalCase leaks or is_deleted.
! stdout '"is_deleted"'
! stdout '"SourceId"'
! stdout '"TargetId"'
