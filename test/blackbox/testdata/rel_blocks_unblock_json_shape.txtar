# Verify that 'np rel blocks unblock --json' produces valid JSON with a, b,
# and action fields.

np-init RU
np-seed task 'Blocker to unblock' rel-agent BLOCKER
np-seed task 'Blocked to unblock' rel-agent BLOCKED
np-seed-rel BLOCKED blocked_by BLOCKER rel-agent

exec np rel blocks unblock $BLOCKER $BLOCKED --author rel-agent --json
np-json-has action unblocked
! np-json-no-field a
! np-json-no-field b
