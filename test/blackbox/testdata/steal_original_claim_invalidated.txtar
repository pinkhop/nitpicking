# Verify that after agent B steals a claim, agent A's original claim ID is
# invalidated — using it for an update fails.

np-init STEAL
np-seed task 'Will be stolen' agent-alpha TASK

# Agent A claims, then agent B steals.
exec np claim $TASK --author agent-alpha --duration 1ms --json
np-capture CLAIM_A claim_id

exec np claim $TASK --author agent-beta --steal --json

# Agent A's update with the old claim fails.
stdin update.json
! exec np json update --claim $CLAIM_A

-- update.json --
{"title": "Agent A update"}
