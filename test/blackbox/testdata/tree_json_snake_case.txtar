# Verify that 'rel tree --json' uses snake_case keys (items, has_more)
# matching the JSON shape of 'np list --json'. Regression test for
# NP-7smy0: rel tree was serializing driving.ListIssuesOutput directly,
# producing PascalCase keys (Items, HasMore).

np-init TJ
np-seed epic 'Tree root' tree-agent EPIC
np-seed task 'Tree child' tree-agent CHILD --parent $EPIC

exec np rel tree $EPIC --json
np-json-array-len items 1
! np-json-no-field has_more

# Items contain expected snake_case fields.
stdout '"id"'
stdout '"role"'
stdout '"state"'
stdout '"priority"'
stdout '"created_at"'

# No PascalCase leaks.
! stdout '"Items"'
! stdout '"HasMore"'
! stdout '"ID"'
! stdout '"Role"'
