# Undefer JSON output: action is "reopen", state returns to open.

np-init UD
np-seed task 'Undefer target' undefer-agent TASK --claim

exec np issue defer --claim $TASK_CLAIM --json

exec np issue undefer $TASK --author undefer-agent --json
np-json-has action reopen
! np-json-no-field issue_id
np-json-no-field is_deleted
! stdout 'IssueID'
! stdout 'Action'

exec np show $TASK --json
np-json-has state open
