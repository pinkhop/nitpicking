# Update labels sets labels, label_remove removes them.

np-init UFLAG
np-seed task 'Label test' flag-agent TASK --claim

# Set two labels.
stdin set_labels.json
exec np json update --claim $TASK_CLAIM

# Both labels appear in list filters.
exec np list --label kind:fix --json
np-json-array-len issues 1

exec np list --label area:auth --json
np-json-array-len issues 1

# Remove one label.
stdin remove_label.json
exec np json update --claim $TASK_CLAIM

# Removed label no longer matches.
exec np list --label area:auth --json
np-json-array-len issues 0

# Remaining label is still present.
exec np list --label kind:fix --json
np-json-array-len issues 1

-- set_labels.json --
{"labels": ["kind:fix", "area:auth"]}

-- remove_label.json --
{"label_remove": ["area"]}
