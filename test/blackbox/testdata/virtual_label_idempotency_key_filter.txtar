# Verify that an issue imported with an idempotency_label can be filtered by
# its actual label key and value. The idempotency_label "jira:abc" is stored
# as a normal label with key "jira" and value "abc", so --label jira:abc finds
# it and --label jira:* matches any issue carrying a "jira" label.

np-init VL
exec np import jsonl testdata/with_label.jsonl --author vl-agent --json
stdin input2.json
exec np json create --author vl-agent

# Exact value match using the actual label key:value.
exec np list --ready --label jira:abc --json
np-json-array-len items 1
stdout 'With label'

# Wildcard match — any issue carrying the "jira" label key.
exec np list --ready --label jira:* --json
np-json-array-len items 1
stdout 'With label'

-- testdata/with_label.jsonl --
{"role":"task","title":"With label","idempotency_label":"jira:abc"}
-- input2.json --
{"role":"task","title":"Without label"}
