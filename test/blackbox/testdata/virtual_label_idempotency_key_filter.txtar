# Verify that --label idempotency-key:<value> filters against the
# idempotency_key column, and --label idempotency-key:* matches any
# issue with an idempotency key.
# Uses import jsonl because idempotency_key is only available via import.

np-init VL
exec np import jsonl testdata/with_key.jsonl --author vl-agent --json
stdin input2.json
exec np json create --author vl-agent

# Exact value match.
exec np list --ready --label idempotency-key:abc --json
np-json-array-len items 1
stdout 'With key'

# Wildcard match — any issue with an idempotency key.
exec np list --ready --label idempotency-key:* --json
np-json-array-len items 1
stdout 'With key'

-- testdata/with_key.jsonl --
{"role":"task","title":"With key","idempotency_key":"abc"}
-- input2.json --
{"role":"task","title":"Without key"}
