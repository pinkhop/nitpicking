# Verify that setting the idempotency-key label via "label add" writes to
# the idempotency_key column, and the value appears in show output.

np-init VL
np-seed task 'Label add test' vl-agent TASK --claim

exec np label add idempotency-key:my-import-id --claim $TASK_CLAIM --json

exec np show $TASK --json
stdout '"idempotency-key": "my-import-id"'
