# Verify that when an issue has an idempotency_key, it appears as the
# virtual label "idempotency-key" in show --json output.
# Uses import jsonl because idempotency_key is only available via import.

np-init VL
exec np import jsonl testdata/with_key.jsonl --author vl-agent --json

# Claim the only ready issue to obtain its ID.
exec np claim ready --author vl-agent --json
np-capture TASK issue_id

exec np show $TASK --json
stdout '"idempotency-key": "import-abc123"'

-- testdata/with_key.jsonl --
{"role":"task","title":"Has idem key","idempotency_key":"import-abc123"}
