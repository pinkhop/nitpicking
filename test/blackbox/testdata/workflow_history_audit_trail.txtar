# History audit trail: a task goes through create, claim, update, release,
# re-claim, and close. The history should record every mutation.

np-init WF
np-seed task 'Audit trail test' audit-agent TASK

exec np claim $TASK --author audit-agent --json
np-capture CLAIM1 claim_id

stdin update.json
exec np json update --claim $CLAIM1
exec np issue release --claim $CLAIM1 --json

exec np claim $TASK --author audit-agent --json
np-capture CLAIM2 claim_id

exec np close --claim $CLAIM2 --reason 'test close' --json

exec np issue history $TASK --json
stdout '"event_type": "created"'
stdout '"event_type": "claimed"'
stdout '"event_type": "updated"'
stdout '"event_type": "released"'
stdout '"event_type": "state_changed"'

-- update.json --
{"title": "Audit trail test (updated)"}
